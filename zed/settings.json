{
  "diff_view_style": "unified",
  "cli_default_open_behavior": "existing_window",
  "project_panel": {
    "dock": "right",
  },
  "outline_panel": {
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "restore_on_startup": "launchpad",
  // Editor
  "ssh_connections": [
    {
      "host": "LA015",
      "args": [],
      "projects": [
        {
          "paths": [
            "/home/ted/dev/anvil2/./"
          ]
        },
        {
          "paths": [
            "/home/tudor"
          ]
        },
        {
          "paths": [
            "/home/ubuntu/Documents/robotics-practicals"
          ]
        }
      ]
    },
    {
      "host": "LA016",
      "args": [],
      "projects": []
    },
    {
      "host": "predict",
      "args": [],
      "projects": [
        {
          "paths": [
            "/home/tudor/dev/controls_challenge/./"
          ]
        }
      ]
    }
  ],
  "agent_servers": {
    },
  "session": {
    "trust_all_worktrees": false,
  },
  "git_panel": {
    "dock": "right",
    "tree_view": true,
  },
  "use_smartcase_search": true,
  "search": {
    "regex": true,
    "case_sensitive": false,
  },
  "tab_size": 2,
  "pane_split_direction_vertical": "right",
  "pane_split_direction_horizontal": "down",
  "show_completions_on_input": true,
  "show_completion_documentation": true,
  "soft_wrap": "none",
  "relative_line_numbers": "enabled",
  "inlay_hints": {
    "enabled": true,
    "show_parameter_hints": true,
    "show_other_hints": true,
  },
  "show_signature_help_after_edits": true,
  // UI
  "unstable.ui_density": "compact",
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": false,
  },
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": true,
  },
  // Fonts
  "buffer_font_size": 12.0,
  "ui_font_size": 14,
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "ui_font_family": "JetBrainsMono Nerd Font",
  "terminal": {
    "copy_on_select": true,
    "font_family": "JetBrainsMono Nerd Font",
    "font_weight": 400,
    "detect_venv": "off",
  },
  // Keymap
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "always",
    "use_smartcase_find": true,
  },
  // Color theme
  "theme": {
    "mode": "system",
    "light": "Zed Legacy: Rosé Pine Dawn",
    "dark": "Zed Legacy: Rosé Pine",
  },
  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha",
  },
  "experimental.theme_overrides": {
    "syntax": {
      "comment": {},
    },
  },
  // Extensions
  "auto_install_extensions": {
    // themes
    "zed-legacy-themes": true,
    "catppuccin-icons": true,
    // git
    "git-firefly": true,
    // LSPs
    "typst": true,
    // file formats
    "toml": true,
    "lua": true,
    "sql": true,
    "log": true,
  },
  // LSP
  "format_on_save": "off",
  "enable_language_server": true,
  // "language_servers": ["!biome"],
  "languages": {
    "YAML": {
      "tab_size": 2,
    },
    // "TypeScript": {
    //   "formatter": [
    //     {
    //       "language_server": {
    //         "name": "biome",
    //       },
    //     },
    //     { "code_action": "source.organizeImports.biome" },
    //   ],
    // },
    // "TSX": {
    //   "formatter": [
    //     {
    //       "language_server": {
    //         "name": "biome",
    //       },
    //     },
    //     { "code_action": "source.organizeImports.biome" },
    //   ],
    // },
    "JSON": {
      "tab_size": 2,
    },
    "JSONC": {
      "tab_size": 2,
    },
    "XML": {
      "tab_size": 2,
    },
    "Python": {
      "language_servers": ["ty", "ruff"],
      "formatter": [
        { "code_action": "source.organizeImports.ruff" },
        { "language_server": { "name": "ruff" } },
      ],
    },
  },
  "lsp": {
    "biome": {
      "binary": {
        "path": "~/.bun/bin/biome",
        "arguments": ["lsp-proxy"],
      },
    },
    "ty": {
      "binary": {
        "path": "/Users/tudoroancea/.local/bin/ty",
        "arguments": ["server"],
      },
    },
    "pyrefly": {
      "binary": {
        "path": "/Users/tudoroancea/.local/bin/pyrefly",
        "arguments": ["lsp"],
      },
    },
    "tinymist": {
      "initialization_options": {
        "exportPdf": "onSave",
        "formatterMode": "typstyle",
      },
    },
  },
  "file_scan_exclusions": [".worktrees/**"],
  // Remote
  // AI
  "show_edit_predictions": true,
  "edit_predictions": {
    "open_ai_compatible_api": {
      "api_url": "http://localhost:8080/v1/completions",
      "max_output_tokens": 1024,
      "prompt_format": "zeta2",
      "model": "bartowski/zed-industries_zeta-2-GGUF",
    },
    "ollama": {
      "max_output_tokens": 1024,
      "prompt_format": "zeta2",
      "api_url": "http://localhost:2276/v1",
    },
    "provider": "zed",
    "disabled_globs": ["*.mlir"],
    "mode": "subtle",
    // "provider": "open_ai_compatible_api",
    // "open_ai_compatible_api": {
    //   "api_url": "http://localhost:8080/v1/completions",
    //   // "model": "zed-industries_zeta-2-Q4_K_M.gguf",

    //   "prompt_format": "zeta2",
    //   "max_output_tokens": 256,
    // },
  },
  "agent": {
    "enable_feedback": false,
    "play_sound_when_agent_done": "when_hidden",
    "expand_edit_card": false,
    "expand_terminal_card": false,
    "cancel_generation_on_terminal_stop": false,
    "show_turn_stats": true,
    "use_modifier_to_send": true,
    "dock": "left",
    "default_profile": "write",
    "default_model": {
      "effort": "medium",
      "enable_thinking": true,
      "provider": "zed.dev",
      "model": "claude-sonnet-4-6",
    },
    "inline_assistant_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4-6",
    },
    "enabled": true,
  },
  // Git
  "git": {
    "hunk_style": "staged_hollow",
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": true,
      "show_commit_summary": true,
      "delay_ms": 500,
    },
  },
  // Misc
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "auto_update": true,
  "autosave": "on_focus_change",
}
