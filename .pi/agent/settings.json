{
  "lastChangelogVersion": "0.66.1",
  "theme": "rosepine-dawn",
  "hideThinkingBlock": true,
  "defaultProvider": "llamacpp",
  "defaultModel": "gemma-4-26b-a4b-q4",
  "defaultThinkingLevel": "low",
  "enabledModels": [
    "pave/gpt-5.3-codex",
    "pave/gpt-5.4",
    "opencode-go/glm-5",
    "opencode-go/kimi-k2.5",
    "opencode-go/minimax-m2.7",
    "llamacpp/gemma-4-26b-a4b-q4"
  ],
  "quietStartup": true,
  "collapseChangelog": true,
  "followUpMode": "all",
  "steeringMode": "all",
  "doubleEscapeAction": "tree",
  "packages": [
    {
      "source": "npm:pi-web-access",
      "extensions": [
        "+index.ts"
      ],
      "skills": [
        "+skills/librarian/SKILL.md"
      ]
    },
    {
      "source": "npm:pi-subagents",
      "extensions": [
        "-index.ts",
        "-notify.ts"
      ]
    },
    {
      "source": "npm:pi-boomerang",
      "extensions": [
        "+index.ts"
      ]
    },
    {
      "source": "https://github.com/davebcn87/pi-autoresearch",
      "extensions": [
        "-extensions/pi-autoresearch/index.ts"
      ],
      "skills": [
        "-skills/autoresearch-create/SKILL.md",
        "-skills/autoresearch-finalize/SKILL.md"
      ]
    },
    {
      "source": "git:https://github.com/badlogic/pi-diff-review",
      "extensions": [
        "-src/index.ts"
      ]
    },
    "git:github.com/championswimmer/pi-context-usage",
    "npm:pi-read-mode"
  ],
  "claudeStyle": {
    "collapsedToolCalls": "excerpt"
  }
}
