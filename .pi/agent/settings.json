{
  "lastChangelogVersion": "0.79.0",
  "theme": "rosepine-dawn",
  "hideThinkingBlock": true,
  "defaultProvider": "pave",
  "defaultModel": "gpt-5.5",
  "defaultThinkingLevel": "high",
  "enabledModels": [
    "pave/gpt-5.5",
    "opencode/nemotron-3-ultra-free",
    "opencode/deepseek-v4-flash-free"
  ],
  "quietStartup": true,
  "collapseChangelog": true,
  "followUpMode": "all",
  "steeringMode": "all",
  "doubleEscapeAction": "tree",
  "packages": [
    {
      "source": "npm:pi-web-access",
      "extensions": [
        "+index.ts"
      ],
      "skills": [
        "+skills/librarian/SKILL.md"
      ]
    },
    {
      "source": "npm:pi-boomerang",
      "extensions": [
        "+index.ts"
      ]
    },
    {
      "source": "git:github.com/championswimmer/pi-context-usage",
      "skills": [
        "-.agents/skills/planning/SKILL.md",
        "-.agents/skills/release/SKILL.md"
      ]
    },
    "npm:pi-goal",
    "npm:pi-tool-display"
  ],
  "claudeStyle": {
    "collapsedToolCalls": "excerpt"
  },
  "extensions": [
    "-extensions/claude-style.ts"
  ],
  "skills": [
    "-skills/frontend-design/SKILL.md"
  ]
}
