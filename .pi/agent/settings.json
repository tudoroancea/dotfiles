{
  "lastChangelogVersion": "0.80.7",
  "theme": "rosepine-dawn/rosepine-moon",
  "hideThinkingBlock": true,
  "defaultProvider": "pave",
  "defaultModel": "gpt-5.6-sol",
  "defaultThinkingLevel": "medium",
  "enabledModels": [
    "pave/gpt-5.6-sol",
    "pave/gpt-5.6-luna",
    "openai-codex/gpt-5.6-sol",
    "openai-codex/gpt-5.6-luna"
  ],
  "quietStartup": true,
  "collapseChangelog": true,
  "followUpMode": "all",
  "steeringMode": "all",
  "doubleEscapeAction": "none",
  "packages": [
    {
      "source": "npm:pi-web-access",
      "extensions": [
        "+index.ts"
      ],
      "skills": [
        "-skills/librarian/SKILL.md"
      ]
    },
    {
      "source": "git:github.com/championswimmer/pi-context-usage",
      "skills": [
        "-.agents/skills/planning/SKILL.md",
        "-.agents/skills/release/SKILL.md"
      ]
    },
    {
      "source": "npm:pi-tool-display",
      "extensions": [
        "-index.ts"
      ]
    },
    "npm:@plannotator/pi-extension"
  ],
  "claudeStyle": {
    "collapsedToolCalls": "excerpt"
  },
  "extensions": [
    "-extensions/claude-style.ts",
    "-extensions/mac-system-theme.ts",
    "-extensions/worktrunk-statusline.ts",
    "-extensions/double-escape.ts"
  ],
  "skills": [
    "-skills/frontend-design/SKILL.md",
    "-skills/plannotator-annotate/SKILL.md",
    "-skills/plannotator-last/SKILL.md",
    "-skills/plannotator-review/SKILL.md"
  ]
}
