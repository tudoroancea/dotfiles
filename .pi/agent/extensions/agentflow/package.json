{
  "name": "pi-agentflow",
  "version": "0.1.0",
  "description": "Isolated child-agent and dynamic workflow runtime for Pi",
  "keywords": [
    "agent",
    "extension",
    "pi",
    "subagent",
    "workflow"
  ],
  "license": "ISC",
  "author": "",
  "type": "module",
  "scripts": {
    "test": "vitest run test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "dev:rpc": "pi --mode rpc --no-session",
    "dev:rpc:raw": "pi --mode rpc --no-session --agentflow-raw",
    "dev:tui": "pi",
    "dev:tui:raw": "pi --agentflow-raw",
    "smoke": "node scripts/rpc-smoke.mjs",
    "smoke:workflow": "node scripts/rpc-workflow-smoke.mjs"
  },
  "dependencies": {
    "acorn": "^8.17.0",
    "acorn-walk": "^8.3.5",
    "typebox": "^1.3.6"
  },
  "devDependencies": {
    "@earendil-works/pi-agent-core": "^0.80.6",
    "@earendil-works/pi-ai": "^0.80.6",
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "@earendil-works/pi-tui": "^0.80.6",
    "@types/acorn": "^4.0.6",
    "@types/node": "^26.1.1",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  }
}
